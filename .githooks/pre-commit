#!/bin/sh
# Pre-commit hook: format staged files and run linters.

# Activate mise-managed tools
eval "$(mise activate bash --shims)" 2>/dev/null

# Prevent direct commits to main/master
_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "$_branch" = "main" ] || [ "$_branch" = "master" ]; then
    echo "ERROR: Direct commits to '$_branch' are not allowed."
    exit 1
fi

set -e

# Format staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')

if [ -n "$STAGED_GO_FILES" ]; then
    gofmt -w .
    echo "$STAGED_GO_FILES" | xargs git add
fi

# Format staged frontend files
STAGED_FE_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'frontend/*.ts' 'frontend/*.js' 'frontend/*.svelte' 'frontend/*.json')

if [ -n "$STAGED_FE_FILES" ]; then
    cd frontend && biome format --write . && cd ..
    echo "$STAGED_FE_FILES" | xargs git add
fi

# Run linters
if [ -n "$STAGED_GO_FILES" ]; then
    make custom-gcl
    ./custom-gcl run ./...
fi

if [ -n "$STAGED_FE_FILES" ]; then
    cd frontend && biome check . && cd ..
fi
